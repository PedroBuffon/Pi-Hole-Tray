<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>PiHoleTray</AssemblyName>
    <RootNamespace>PiHoleTray</RootNamespace>
    <AllowUnsafeBlocks>false</AllowUnsafeBlocks>
    <ApplicationIcon>app.ico</ApplicationIcon>

    <!-- Publish: self-contained single file -->
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>

    <!--
      Size optimisation (WinForms does not support IL trimming):
        PublishReadyToRun=false → only MSIL, no duplicate native code  (~-50 MB)
        EnableCompressionInSingleFile=true → zlib-compress bundle      (~-30 MB)
    -->
    <PublishReadyToRun>false</PublishReadyToRun>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
  </PropertyGroup>

</Project>
